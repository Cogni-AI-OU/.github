{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".github/skills/AGENTS.md"
  ],
  "agent": {
    "cogni-ai": {
      "mode": "primary",
      "model": "opencode/gpt-5.3-codex",
      "prompt": "{file:../.github/agents/cogni-ai.agent.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      // Keep shell permissions aligned with .devcontainer/devcontainer.json bootstrap commands.
      "permission": {
        "bash": {
          "mkdir -p \"$HOME/.local/share/opencode\" \"$HOME/.config/opencode\"": "allow",
          "sudo apt update": "allow",
          "xargs -a .devcontainer/apt-packages.txt sudo apt-get install -y": "allow",
          "pip install -r .devcontainer/requirements.txt": "allow",
          "time pip install -r .devcontainer/requirements.txt": "allow",
          "pipx install --include-deps --force ansible": "allow",
          "time pipx install --include-deps --force ansible": "allow",
          "pipx inject ansible -r .devcontainer/requirements-ansible.txt": "allow",
          "time pipx inject ansible -r .devcontainer/requirements-ansible.txt": "allow",
          "pre-commit install": "allow",
          "time pre-commit install": "allow"
        }
      }
    }
  },
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
