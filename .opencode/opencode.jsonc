{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".github/skills/AGENTS.md"
  ],
  "agent": {
    "cogni-ai": {
      "mode": "primary",
      "model": "opencode/gpt-5.3-codex",
      "prompt": "{file:../.github/agents/cogni-ai.agent.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
